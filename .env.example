# ─── DATABASE ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/sixd_ops

# ─── NEXTAUTH ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# ─── EMAIL (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@sixdengineering.com
SMTP_PASS=your-app-password
EMAIL_FROM="SixD Ops <noreply@sixdengineering.com>"

# ─── FILE STORAGE ────────────────────────────────────────────────────────────
# Absolute path to upload directory on the VPS
UPLOAD_DIR=./uploads
# Max file size in megabytes
MAX_FILE_SIZE_MB=10

# ─── APPLICATION ─────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
# Session expiry in hours (default: 8)
SESSION_EXPIRY_HOURS=8
# Secret token to protect /api/cron/* endpoints (use a long random string)
CRON_SECRET=your-cron-secret-here

# ─── GST ─────────────────────────────────────────────────────────────────────
# Default GST percent applied when client has no override
DEFAULT_GST_PERCENT=18

# ─── COMPANY INFO (used in invoice PDF) ──────────────────────────────────────
COMPANY_NAME="SixD Engineering Solutions Pvt. Ltd."
COMPANY_ADDRESS="Noida, Uttar Pradesh, India"
COMPANY_GSTIN=07AAJCS1234A1Z5
COMPANY_PAN=AAJCS1234A
COMPANY_EMAIL=info@sixdengineering.com
COMPANY_PHONE="+91-XXXXXXXXXX"
COMPANY_BANK_NAME="HDFC Bank"
COMPANY_BANK_ACCOUNT=XXXXXXXXXXXXXXXXXX
COMPANY_BANK_IFSC=HDFC0001234
COMPANY_BANK_BRANCH="Noida Branch"
